{
  "version": 2,
  "framework": null,
  "buildCommand": null,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/obrigado", "destination": "/obrigado.html" },
    { "source": "/portal-do-cliente", "destination": "/obrigado.html" },
    { "source": "/bonus/guia-anti-ban", "destination": "/guia-anti-ban.html" },
    { "source": "/bonus/templates-campanha", "destination": "/templates-campanha.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
