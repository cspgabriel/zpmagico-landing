# =============================================================================
# ZapMágico — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para `.env` e preencha os valores reais.
# NUNCA commite o .env no git (já está no .gitignore).
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
# Postgres do Docker que já roda (compose em /docker). Porta 5435 mapeia pra 5432 interna.
DATABASE_URL="postgresql://evolution:565d3b31fb50ce4f2ca6af00abd54e8b@localhost:5435/zapmagico_saas?schema=public"

# ─── NextAuth (Auth.js v5) ────────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
AUTH_SECRET="CHANGE-ME-generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3001"
AUTH_TRUST_HOST="true"

# ─── Evolution API (Docker local) ─────────────────────────────────────────────
# A mesma que está em docker/.env (EVOLUTION_API_KEY)
EVOLUTION_API_URL="http://localhost:8083"
EVOLUTION_API_KEY="CHANGE-ME-paste-the-same-key-from-docker-env"

# URL pública que o container Docker da Evolution usa pra alcançar ESTE SaaS.
# No Docker Desktop Windows, host.docker.internal resolve pra host.
SAAS_PUBLIC_URL="http://host.docker.internal:3001"

# ─── Asaas (Billing — sandbox por padrão) ────────────────────────────────────
# Crie conta em https://www.asaas.com/, gere API key em "Integrações".
ASAAS_API_KEY="CHANGE-ME-asaas-api-key"
ASAAS_WEBHOOK_TOKEN="CHANGE-ME-asaas-webhook-token"
ASAAS_ENVIRONMENT="sandbox" # sandbox | production

# ─── Observabilidade ──────────────────────────────────────────────────────────
# Sentry (opcional, mas recomendado em prod). Crie projeto em sentry.io.
SENTRY_DSN=""

# ─── Admin Seed (rodar `npm run seed`) ────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@agenciar.com.br"
SEED_ADMIN_PASSWORD="admin123!@#"